---
interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  name: string;
  role: string;
  bio: string;
  socials: SocialLink[];
  photoSrc?: string;
}

const { name, role, bio, socials, photoSrc } = Astro.props;

const initials = () => {
  const parts = name.trim().split(/\s+/);
  if (parts.length >= 2) {
    return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  }
  return name.slice(0, 2).toUpperCase();
};

