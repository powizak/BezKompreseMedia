const getSocialIcon = (platform: string) => {
  const key = platform.toLowerCase();
  return socialIcons[key];
};
---

<article class="team-card scroll-reveal">
  <div class="card-content">
    <div class="avatar-wrapper">
      {photoSrc ? (
        <img src={photoSrc} alt={name} class="avatar-image" />
      ) : (
        <div class="avatar-initials">
          <span class="initials-text">{initials()}</span>
        </div>
      )}
    </div>

    <div class="info-wrapper">
      <h3 class="member-name">{name}</h3>
      <p class="member-role">{role}</p>
      <p class="member-bio">{bio}</p>

      {socials && socials.length > 0 && (
        <div class="social-links">
          {socials.map((social) => {
            const iconPath = getSocialIcon(social.platform);
            return iconPath ? (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.platform}
                class="social-link"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="20" height="20" fill="currentColor" set:html={iconPath}></svg>
              </a>
            ) : null;
          })}
        </div>
      )}
    </div>
  </div>
</article>

<style>
  .team-card {
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    padding: var(--space-5);
    gap: var(--space-4);
  }

  .avatar-wrapper {
    width: fit-content;
  }

  .avatar-image {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full);
    object-fit: cover;
    background-color: var(--color-bg);
  }

  .avatar-initials {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full);
    background-color: var(--color-brand);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .initials-text {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: var(--weight-bold);
    color: var(--color-black);
    line-height: 1;
  }

  .info-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .member-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-black);
    margin: 0;
    line-height: var(--leading-tight);
  }

  .member-role {
    font-size: var(--text-sm);
    color: var(--color-brand-dark);
    margin: 0;
    line-height: var(--leading-snug);
  }

  .member-bio {
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: var(--leading-normal);
  }

  .social-links {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--color-text);
    border-radius: var(--radius-sm);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: color var(--transition-fast), background-color var(--transition-fast), border-color var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-black);
    background-color: var(--color-brand);
    border-color: var(--color-brand);
  }

  .social-link svg {
    width: 16px;
    height: 16px;
  }

  @media (min-width: 640px) {
    .card-content {
      flex-direction: row;
      align-items: flex-start;
      padding: var(--space-6);
      gap: var(--space-5);
    }

    .avatar-wrapper {
      flex-shrink: 0;
    }

    .avatar-image,
    .avatar-initials {
      width: 96px;
      height: 96px;
    }

    .initials-text {
      font-size: 2.5rem;
    }

    .info-wrapper {
      flex: 1;
    }

    .member-name {
      font-size: var(--text-xl);
    }

    .member-role {
      font-size: var(--text-base);
    }

    .member-bio {
      font-size: var(--text-base);
    }
  }

  @media (min-width: 1024px) {
    .card-content {
      padding: var(--space-8);
      gap: var(--space-6);
    }

    .avatar-image,
    .avatar-initials {
      width: 112px;
      height: 112px;
    }

    .initials-text {
      font-size: 3rem;
    }
  }
</style>
