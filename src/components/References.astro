---
// References component - client logos section
import { Image } from 'astro:assets';
import atrium from '../assets/references/atrium.png';
import martinice from '../assets/references/martinice.webp';
import cebia from '../assets/references/cebia.png';
import unitedNetworks from '../assets/references/united-networks.webp';

const references = [
  { href: 'https://www.atrium.cz/', logo: atrium, alt: 'Logo Atrium' },
  { href: 'https://www.martinicegroup.cz/', logo: martinice, alt: 'Logo Martinice Group' },
  { href: 'https://bit.ly/zkontrolujsiauto', logo: cebia, alt: 'Logo Cebia' },
  { href: 'https://www.unitednetworks.cz/', logo: unitedNetworks, alt: 'Logo United Networks' },
];
---

<section class="references scroll-reveal">
  <h2>Naše reference</h2>
  <div class="references-grid">
    {
      references.map((ref) => (
        <a href={ref.href} target="_blank" rel="noopener" class="reference-link">
          <Image
            src={ref.logo}
            alt={ref.alt}
            height={60}
            densities={[1, 2]}
            format="webp"
            loading="lazy"
            class="reference-logo"
          />
        </a>
      ))
    }
  </div>
</section>

<style>
  .references {
    padding: var(--space-20) var(--container-padding);
    text-align: center;
  }

  .references h2 {
    font-size: var(--text-3xl);
    color: var(--color-text);
    margin-bottom: var(--space-8);
    font-weight: var(--weight-bold);
  }

  .references-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-6);
  }

  .reference-link {
    display: block;
    transition: transform var(--transition-base) ease;
  }

  .reference-link:hover {
    transform: translateY(-4px);
  }

  .reference-logo {
    max-height: 50px;
    width: auto;
    filter: grayscale(100%);
    opacity: 0.7;
    transition:
      filter var(--transition-base) ease,
      opacity var(--transition-base) ease;
  }

  .reference-link:hover .reference-logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  @media (min-width: 641px) {
    .references-grid {
      gap: var(--space-8);
    }

    .reference-logo {
      max-height: 60px;
    }
  }
</style>
