---
// References component - client logos section
---

<section class="references scroll-reveal">
  <h2>Naše reference</h2>
  <div class="references-grid">
    <a href="https://www.atrium.cz/" target="_blank" rel="noopener" class="reference-link">
      <img src="/images/references/atrium.png" alt="Logo Atrium" loading="lazy" class="reference-logo" />
    </a>
    <a href="https://www.martinicegroup.cz/" target="_blank" rel="noopener" class="reference-link">
      <img src="/images/references/martinice.webp" alt="Logo Martinice Group" loading="lazy" class="reference-logo" />
    </a>
    <a href="https://bit.ly/zkontrolujsiauto" target="_blank" rel="noopener" class="reference-link">
      <img src="/images/references/cebia.png" alt="Logo Cebia" loading="lazy" class="reference-logo" />
    </a>
    <a href="https://www.unitednetworks.cz/" target="_blank" rel="noopener" class="reference-link">
      <img src="/images/references/united-networks.webp" alt="Logo United Networks" loading="lazy" class="reference-logo" />
    </a>
  </div>
</section>

<style>
  .references {
    padding: var(--spacing-section) var(--spacing-container);
    text-align: center;
  }

  .references h2 {
    font-size: var(--font-size-heading);
    color: var(--color-text);
    margin-bottom: var(--spacing-lg);
    font-weight: var(--font-weight-semibold);
  }

  .references-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .reference-link {
    display: block;
    transition: transform var(--transition-duration) ease;
  }

  .reference-link:hover {
    transform: translateY(-4px);
  }

  .reference-logo {
    max-height: 60px;
    width: auto;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: filter var(--transition-duration) ease, opacity var(--transition-duration) ease;
  }

  .reference-link:hover .reference-logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  /* Asymmetric vertical offsets for visual interest */
  .references-grid .reference-link:nth-child(1) .reference-logo {
    margin-top: 0;
  }

  .references-grid .reference-link:nth-child(2) .reference-logo {
    margin-top: 2px;
  }

  .references-grid .reference-link:nth-child(3) .reference-logo {
    margin-top: -2px;
  }

  .references-grid .reference-link:nth-child(4) .reference-logo {
    margin-top: 1px;
  }

  @media (max-width: 640px) {
    .references-grid {
      gap: var(--spacing-md);
    }

    .reference-logo {
      max-height: 50px;
    }
  }
</style>
