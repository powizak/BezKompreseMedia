---
// GalleryGrid.astro — shared photo grid with lightbox links.
// Thumbnails are 600×400 (a few slightly taller) → fixed aspect-ratio + object-fit
// keeps the grid uniform and prevents layout shift.
// With `initialCount`, extra photos render with the `hidden` attribute and a
// "show more" button reveals them (they are still part of the lightbox).

export interface GridPhoto {
  thumb: string;
  full: string;
  alt: string;
}

interface Props {
  photos: GridPhoto[];
  label: string;
  initialCount?: number;
  colsMobile?: number;
  colsDesktop?: number;
}

const { photos, label, initialCount, colsMobile = 2, colsDesktop = 4 } = Astro.props;
const visibleCount = initialCount ?? photos.length;
const hiddenCount = photos.length - visibleCount;
---

<div class="gallery-grid" style={`--cols-mobile: ${colsMobile}; --cols-desktop: ${colsDesktop};`}>
  {
    photos.map((photo, i) => (
      <a
        href={photo.full}
        class="glightbox gallery-photo"
        data-gallery={label}
        hidden={i >= visibleCount}
      >
        <img
          src={photo.thumb}
          alt={photo.alt}
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </a>
    ))
  }
</div>
{
  hiddenCount > 0 && (
    <button class="gallery-show-more" type="button" data-show-more>
      Zobrazit více ({hiddenCount} fotek)
    </button>
  )
}

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-show-more]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const grid = btn.previousElementSibling;
      grid?.querySelectorAll('[hidden]').forEach((el) => el.removeAttribute('hidden'));
      btn.remove();
    });
  });
</script>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols-mobile, 2), 1fr);
    gap: var(--space-4);
  }

  .gallery-photo {
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .gallery-photo[hidden] {
    display: none;
  }

  .gallery-photo img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-base);
  }

  .gallery-photo:hover img {
    transform: scale(1.02);
  }

  .gallery-show-more {
    display: block;
    margin: var(--space-8) auto 0;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-black);
    background-color: var(--color-brand);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition:
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .gallery-show-more:hover {
    background-color: var(--color-brand-dark);
    transform: translateY(-1px);
  }

  @media (min-width: 769px) {
    .gallery-grid {
      grid-template-columns: repeat(var(--cols-desktop, 4), 1fr);
      gap: var(--space-6);
    }
  }
</style>
