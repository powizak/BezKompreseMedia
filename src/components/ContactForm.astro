---
const hcaptchaSiteKey = import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY;
const csrfSecret = import.meta.env.PUBLIC_CSRF_SECRET || 'bkmedia_csrf_2026';
---

<section class="section contact-section">
  <div class="container">
    <div class="scroll-reveal">
      <h2 class="contact-heading">Kontaktujte nás</h2>

      <form class="contact-form" method="POST" action="/contact-handler.php">
        <input type="hidden" name="csrf_token" id="csrf_token" />
        <div class="form-field">
          <input
            type="text"
            name="jmeno"
            required
            placeholder="Jméno *"
            autocomplete="name"
          />
        </div>

        <div class="form-field">
          <input
            type="email"
            name="email"
            required
            placeholder="Email *"
            autocomplete="email"
          />
        </div>

        <div class="form-field">
          <input
            type="tel"
            name="telefon"
            placeholder="Telefonní číslo"
            autocomplete="tel"
          />
        </div>

        <div class="form-field">
          <textarea
            name="poptavka"
            required
            placeholder="Vaše poptávka *"
            rows="5"
          ></textarea>
        </div>

        <!-- Honeypot — hidden from real users, bots will fill it -->
        <div style="display:none" aria-hidden="true">
          <input
            type="text"
            name="url"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <div class="form-field hcaptcha-field">
          <div class="h-captcha" data-sitekey={hcaptchaSiteKey}></div>
        </div>

        <button type="submit" class="btn-submit">Odeslat poptávku</button>
      </form>
    </div>
  </div>
</section>

<script src="https://js.hcaptcha.com/1/api.js" async defer></script>

<script define:vars={{ csrfSecret }}>
  // Generate time-based HMAC CSRF token using Web Crypto API
  async function generateCsrfToken() {
    const window_ = Math.floor(Date.now() / 3600000);
    const encoder = new TextEncoder();
    const key = await crypto.subtle.importKey(
      'raw', encoder.encode(csrfSecret), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']
    );
    const sig = await crypto.subtle.sign('HMAC', key, encoder.encode(String(window_)));
    const hash = Array.from(new Uint8Array(sig)).map(b => b.toString(16).padStart(2, '0')).join('');
    const field = document.getElementById('csrf_token');
    if (field) field.value = hash;
  }
  generateCsrfToken();
</script>

<style>
  .contact-section {
    background-color: var(--color-bg-alt);
  }

  .contact-heading {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .contact-form {
    max-width: 600px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    color: var(--color-text);
    background-color: var(--color-white);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgba(var(--color-brand-rgb), 0.15);
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--color-text-light);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .hcaptcha-field {
    display: flex;
    justify-content: flex-start;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4) var(--space-8);
    border: none;
    border-radius: var(--radius-md);
    background-color: var(--color-brand);
    color: var(--color-black);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    cursor: pointer;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .btn-submit:hover {
    background-color: var(--color-brand-dark);
    transform: translateY(-1px);
  }

  .btn-submit:active {
    transform: translateY(0);
  }
</style>
