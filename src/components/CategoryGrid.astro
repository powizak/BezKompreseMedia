---
interface Props {
  heading: string;
  intro: string;
  categories: { title: string; description: string }[];
}

const { heading, intro, categories } = Astro.props;
---

<section class="category-grid section">
  <div class="container">
    <header class="category-grid-header scroll-reveal">
      <h2 class="category-grid-heading">{heading}</h2>
      <p class="category-grid-intro">{intro}</p>
    </header>

    <div class="category-grid-grid">
      {categories.map((cat, i) => (
        <article
          class={`category-grid-card scroll-reveal category-grid-card--${i + 1}`}
          data-delay={i * 100}
        >
          <h3 class="category-grid-card__title">{cat.title}</h3>
          <p class="category-grid-card__desc">{cat.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* === Header === */
  .category-grid-header {
    text-align: center;
    margin-bottom: var(--space-16);
    max-width: 680px;
    margin-inline: auto;
  }

  .category-grid-heading {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .category-grid-intro {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-light);
  }

  /* === Grid: mobile-first base === */
  .category-grid-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: start;
  }

  /* === Card === */
  .category-grid-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-brand);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    position: relative;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base);
    box-shadow: var(--shadow-sm);
  }

  .category-grid-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .category-grid-card__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .category-grid-card__desc {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-light);
  }

  /* === Responsive: asymmetric 12-col grid === */
  @media (min-width: 769px) {
    .category-grid-grid {
      grid-template-columns: repeat(12, 1fr);
      gap: var(--space-6);
    }

    /* Row 1 — wider left, narrower right offset down */
    .category-grid-card--1 {
      grid-column: 1 / 8;
      grid-row: 1 / 2;
      margin-top: 0;
    }

    .category-grid-card--2 {
      grid-column: 8 / 13;
      grid-row: 1 / 2;
      margin-top: var(--space-10);
    }

    /* Row 2 — narrower left shifted up, wider right offset down */
    .category-grid-card--3 {
      grid-column: 1 / 6;
      grid-row: 2 / 3;
      margin-top: calc(-1 * var(--space-4));
    }

    .category-grid-card--4 {
      grid-column: 6 / 13;
      grid-row: 2 / 3;
      margin-top: var(--space-4);
    }

    /* Row 3 — mirror row 1 asymmetry */
    .category-grid-card--5 {
      grid-column: 1 / 7;
      grid-row: 3 / 4;
      margin-top: var(--space-4);
    }

    .category-grid-card--6 {
      grid-column: 7 / 13;
      grid-row: 3 / 4;
      margin-top: var(--space-8);
    }
  }
</style>
