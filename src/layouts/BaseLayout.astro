---
import '../styles/global.css';
import 'glightbox/dist/css/glightbox.css';
import { Image } from 'astro:assets';
import logoSrc from '../assets/logo.png';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BezKomprese Media - Budujeme Vaši digitální identitu',
  description = 'BezKomprese Media - Profesionální fotografie, video, tvorba webových stránek, správa sociálních sítí, vše, co posune Vaši firmu kupředu v digitálním světě.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Náš tým', href: '/nas-tym/' },
  { label: 'Foto', href: '/foto/' },
  { label: 'Video', href: '/video/' },
  { label: 'Web', href: '/web/' },
  { label: 'Sociální sítě', href: '/socialni-site/' },
  { label: 'Galerie', href: '/galerie/' },
  { label: 'Ceník', href: '/cenik/' },
];

const footerServices = [
  { label: 'Náš tým', href: '/nas-tym/' },
  { label: 'Foto', href: '/foto/' },
  { label: 'Video', href: '/video/' },
  { label: 'Web', href: '/web/' },
  { label: 'Sociální sítě', href: '/socialni-site/' },
  { label: 'Galerie', href: '/galerie/' },
  { label: 'Ceník', href: '/cenik/' },
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="BezKomprese Media" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="180x180" href="/favicon-180.png" />
    <link rel="apple-touch-icon" href="/favicon-180.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Space+Grotesk:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- CookieYes Consent Banner -->
    <script id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client-data/a7112a29b80640e7b97f9df6/script.js"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner container">
        <a href="/" class="logo-link" aria-label="BezKomprese Media – Domů">
          <Image src={logoSrc} alt="BezKomprese Media logo" width={100} height={100} />
        </a>

        <nav class="nav-desktop" aria-label="Hlavní navigace">
          <ul class="nav-list">
            {navItems.map((item) => (
              <li>
                <a href={item.href} class="nav-link">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
          <a href="/contact/" class="cta-button">Kontakt</a>
        </nav>

        <button
          class="hamburger"
          type="button"
          aria-label="Otevřít menu"
          aria-expanded="false"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>

      <nav class="nav-mobile" aria-label="Mobilní navigace">
        <ul class="nav-mobile-list">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="nav-mobile-link">
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/contact/" class="cta-button">Kontakt</a>
          </li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-grid container">
        <!-- Column 1: O nás -->
        <div class="footer-col">
          <h3 class="footer-heading">O nás</h3>
          <p class="footer-text">
            Naše firma je sice mladá, ale společně máme mnoholeté zkušenosti ve všech námi nabízených odvětvích.
          </p>
          <div class="social-icons">
            <a href="https://www.facebook.com/bezkomprese" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="24" height="24" fill="currentColor">
                <path d="M400 32H48A48 48 0 0 0 0 80v352a48 48 0 0 0 48 48h137.25V327.69h-63V256h63v-54.64c0-62.15 37-96.48 93.67-96.48 27.14 0 55.52 4.84 55.52 4.84v61h-31.27c-30.81 0-40.42 19.12-40.42 38.73V256h68.78l-11 71.69h-57.78V480H400a48 48 0 0 0 48-48V80a48 48 0 0 0-48-48z"/>
              </svg>
            </a>
            <a href="https://www.youtube.com/bezkomprese" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" width="24" height="24" fill="currentColor">
                <path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.321 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"/>
              </svg>
            </a>
            <a href="https://www.instagram.com/bezkompresemedia/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="24" height="24" fill="currentColor">
                <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.6 102.7-9 132.1z"/>
              </svg>
            </a>
            <a href="https://www.linkedin.com/company/bezkomprese-media/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="24" height="24" fill="currentColor">
                <path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Column 2: Naše služby -->
        <div class="footer-col">
          <h3 class="footer-heading">Naše služby</h3>
          <ul class="footer-services-list">
            {footerServices.map((item) => (
              <li>
                <a href={item.href} class="footer-link">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 3: Kontakt -->
        <div class="footer-col">
          <h3 class="footer-heading">Kontakt</h3>
          <address class="footer-address">
            <p>BezKomprese shop</p>
            <p>Tyršova 682/IV, 339 01 Klatovy</p>
            <p>
              Tel.: <a href="tel:+420731466375" class="footer-link">+420 731 466 375</a>
            </p>
            <p>
              Email: <a href="mailto:info@bezkompresemedia.cz" class="footer-link">info@bezkompresemedia.cz</a>
            </p>
            <p>Po domluvě kdykoliv</p>
          </address>
        </div>

        <!-- Column 4: Provozovatelé -->
        <div class="footer-col">
          <h3 class="footer-heading">Provozovatelé</h3>
          <p class="footer-text">
            Robin Valeš<br />
            Pohoří 1, Plánice 340 34<br />
            IČ: 08850771<br />
            DIČ: CZ9405122034<br />
            Petr Motyčka, IČ: 10698671<br />
            Jakub Prošek, IČ: 88204511
          </p>
        </div>
      </div>

      <div class="footer-bottom container">
        <p>Copyright &copy; 2026 BezKomprese Media</p>
        <p>Powered by <a href="/" class="footer-link">BezKomprese Media</a></p>
      </div>
    </footer>

    <script src="../scripts/scroll-animations.js"></script>
    <script>
      const hamburger = document.querySelector('.hamburger');
      const mobileNav = document.querySelector('.nav-mobile');
      hamburger?.addEventListener('click', () => {
        mobileNav?.classList.toggle('open');
        hamburger.classList.toggle('active');
        const isOpen = mobileNav?.classList.contains('open');
        hamburger.setAttribute('aria-expanded', String(isOpen));
      });
    </script>

    <script>
      import GLightbox from 'glightbox';
      const lightbox = GLightbox({
        selector: '.glightbox',
        touchNavigation: true,
        loop: true,
        zoomable: true,
      });
      window.GLightboxInstance = lightbox;
    </script>

    <style>
      /* ===== HEADER ===== */
      .site-header {
        position: sticky;
        top: 0;
        z-index: var(--z-sticky);
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        height: 72px;
      }

      .logo-link {
        flex-shrink: 0;
        line-height: 0;
      }

      .logo-link img {
        width: 48px;
        height: 48px;
        object-fit: contain;
      }

      /* ===== DESKTOP NAV ===== */
      .nav-desktop {
        display: none;
        align-items: center;
        gap: var(--space-6);
      }

      .nav-list {
        display: flex;
        align-items: center;
        gap: var(--space-1);
      }

      .nav-link {
        display: inline-block;
        padding: var(--space-2) var(--space-3);
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: var(--weight-regular);
        color: var(--color-text);
        border-radius: var(--radius-sm);
        transition: color var(--transition-fast), background-color var(--transition-fast);
      }

      .nav-link:hover {
        color: var(--color-black);
        background-color: var(--color-bg-alt);
      }

      .cta-button {
        display: inline-block;
        padding: var(--space-2) var(--space-6);
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: var(--weight-bold);
        color: var(--color-black);
        background-color: var(--color-brand);
        border-radius: var(--radius-full);
        border: none;
        cursor: pointer;
        text-align: center;
        transition: background-color var(--transition-fast), transform var(--transition-fast);
      }

      .cta-button:hover {
        background-color: var(--color-brand-dark);
        transform: translateY(-1px);
      }

      /* ===== HAMBURGER ===== */
      .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        padding: 6px;
        background: none;
        border: none;
        cursor: pointer;
      }

      .hamburger-line {
        display: block;
        width: 100%;
        height: 2px;
        background-color: var(--color-black);
        border-radius: 2px;
        transition: transform var(--transition-fast), opacity var(--transition-fast);
      }

      .hamburger.active .hamburger-line:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }

      .hamburger.active .hamburger-line:nth-child(2) {
        opacity: 0;
      }

      .hamburger.active .hamburger-line:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      /* ===== MOBILE NAV ===== */
      .nav-mobile {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.97);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
        box-shadow: var(--shadow-lg);
        padding: var(--space-4);
      }

      .nav-mobile.open {
        display: block;
      }

      .nav-mobile-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
      }

      .nav-mobile-link {
        display: block;
        padding: var(--space-3) var(--space-4);
        font-family: var(--font-body);
        font-size: var(--text-base);
        color: var(--color-text);
        border-radius: var(--radius-sm);
        transition: color var(--transition-fast), background-color var(--transition-fast);
      }

      .nav-mobile-link:hover {
        color: var(--color-black);
        background-color: var(--color-bg-alt);
      }

      .nav-mobile-list .cta-button {
        margin-top: var(--space-3);
        text-align: center;
      }

      /* ===== FOOTER ===== */
      .site-footer {
        background-color: var(--color-bg-dark);
        color: var(--color-white);
        padding-top: var(--space-16);
        padding-bottom: var(--space-8);
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-10);
        padding-bottom: var(--space-10);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }

      .footer-heading {
        font-family: var(--font-display);
        font-size: var(--text-lg);
        font-weight: var(--weight-bold);
        color: var(--color-white);
        margin-bottom: var(--space-4);
      }

      .footer-text {
        font-size: var(--text-sm);
        color: rgba(255, 255, 255, 0.7);
        line-height: var(--leading-relaxed);
      }

      .footer-address {
        font-style: normal;
        font-size: var(--text-sm);
        color: rgba(255, 255, 255, 0.7);
        line-height: var(--leading-relaxed);
      }

      .footer-address p {
        margin-bottom: var(--space-1);
      }

      .footer-link {
        color: rgba(255, 255, 255, 0.7);
        transition: color var(--transition-fast);
      }

      .footer-link:hover {
        color: var(--color-brand);
      }

      .footer-services-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }

      .footer-services-list a {
        font-size: var(--text-sm);
        color: rgba(255, 255, 255, 0.7);
        transition: color var(--transition-fast);
      }

      .footer-services-list a:hover {
        color: var(--color-brand);
      }

      .footer-bottom {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-2);
        padding-top: var(--space-6);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.5);
        text-align: center;
      }

      /* ===== SOCIAL ICONS ===== */
      .social-icons {
        display: flex;
        gap: var(--space-3);
        margin-top: var(--space-4);
      }

      .social-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        color: rgba(255, 255, 255, 0.7);
        border-radius: var(--radius-sm);
        transition: color var(--transition-fast), background-color var(--transition-fast);
      }

      .social-icon:hover {
        color: var(--color-white);
        background-color: rgba(255, 255, 255, 0.1);
      }

      .social-icon svg {
        width: 20px;
        height: 20px;
      }

      /* ===== DESKTOP BREAKPOINT ===== */
      @media (min-width: 769px) {
        .nav-desktop {
          display: flex;
        }

        .hamburger {
          display: none;
        }

        .logo-link img {
          width: 64px;
          height: 64px;
        }

        .header-inner {
          height: 80px;
        }

        .footer-grid {
          grid-template-columns: repeat(4, 1fr);
        }

        .footer-bottom {
          flex-direction: row;
          justify-content: space-between;
        }
      }
    </style>

    <style is:global>
      /* GLightbox overrides */
      .goverlay {
        background: rgba(0, 0, 0, 0.92) !important;
      }

      .gclose,
      .gprev,
      .gnext {
        color: rgba(255, 255, 255, 0.9) !important;
        transition: color 150ms ease !important;
      }

      .gclose:hover,
      .gprev:hover,
      .gnext:hover {
        color: var(--color-brand) !important;
      }

      .gclose svg,
      .gprev svg,
      .gnext svg {
        width: 28px;
        height: 28px;
      }

      .gcounter {
        color: rgba(255, 255, 255, 0.8);
        font-family: var(--font-body);
        font-size: 14px;
      }

      .gslide-image img {
        max-height: 90vh;
        object-fit: contain;
      }

      @media (max-width: 768px) {
        .gclose svg,
        .gprev svg,
        .gnext svg {
          width: 24px;
          height: 24px;
        }

        .gprev,
        .gnext {
          padding: 8px;
        }
      }
    </style>
  </body>
</html>
