---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceHero from '../components/ServiceHero.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import PageCTA from '../components/PageCTA.astro';
import {
  webHero,
  webCategories,
  webProcessIntro,
  webProcessSteps,
  webPortfolio,
} from '../data/web';
---
<BaseLayout title="Web - BezKomprese Media">

  <ServiceHero
    title={webHero.title}
    subtitle={webHero.subtitle}
    intro={webHero.intro}
  />

  <CategoryGrid
    heading="Kategorie služeb"
    intro="Veškeré naše jednotlivé služby jsou poskytovány na profesionální úrovni a nemusíte se bát jakoukoliv z nich využít. Pokud nenajdete kategorii, kterou hledáte, i tak se neváhejte ozvat."
    categories={webCategories}
  />

  <!-- Process Section -->
  <section class="process-section section">
    <div class="container">
      <header class="process-header scroll-reveal">
        <h2 class="process-heading">Jak to probíhá?</h2>
        <p class="process-intro">{webProcessIntro}</p>
      </header>

      <div class="process-steps">
        {webProcessSteps.map((step, i) => (
          <div
            class={`process-step scroll-reveal ${i % 2 === 0 ? 'process-step--left' : 'process-step--right'}`}
            data-delay={i * 100}
          >
            <span class="step-number">{step.number}</span>
            <div class="step-content">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section class="portfolio-section section">
    <div class="container">
      <h2 class="portfolio-heading scroll-reveal">A jak to pak může vypadat?</h2>

      <div class="portfolio-grid">
        {webPortfolio.map((item, i) => (
          <article
            class={`portfolio-card scroll-reveal ${i % 2 === 0 ? 'portfolio-card--wide' : 'portfolio-card--narrow'}`}
            data-delay={i * 150}
          >
            <div class="portfolio-thumbnail">
              <span class="portfolio-thumbnail-label">{item.title}</span>
            </div>
            <div class="portfolio-body">
              <h3 class="portfolio-title">{item.title}</h3>
              <div class="portfolio-tags">
                {item.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <a
                class="portfolio-link"
                href={`https://${item.url}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {item.urlText}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <PageCTA />

</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════
     PROCESS SECTION
     ══════════════════════════════════════════════════ */

  .process-section {
    background: var(--color-bg-alt);
  }

  .process-header {
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
    margin-bottom: var(--space-16);
  }

  .process-heading {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .process-intro {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-light);
  }

  /* Steps stack vertically on mobile */
  .process-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .process-step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    position: relative;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base);
    box-shadow: var(--shadow-sm);
  }

  .process-step:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .step-number {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-bg-dark);
    background: var(--color-brand);
    border-radius: var(--radius-full);
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .step-desc {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-light);
  }

  /* Desktop: asymmetric 12-col grid */
  @media (min-width: 769px) {
    .process-steps {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: var(--space-6);
    }

    .process-step--left {
      grid-column: 1 / 8;
    }

    .process-step--right {
      grid-column: 6 / 13;
    }

    /* Stagger vertical offsets for rhythm */
    .process-step:nth-child(1) { margin-top: 0; }
    .process-step:nth-child(2) { margin-top: var(--space-10); }
    .process-step:nth-child(3) { margin-top: calc(-1 * var(--space-4)); }
    .process-step:nth-child(4) { margin-top: var(--space-8); }

    .step-number {
      width: 56px;
      height: 56px;
      font-size: var(--text-2xl);
    }

    .step-title {
      font-size: var(--text-2xl);
    }

    .step-desc {
      font-size: var(--text-base);
    }
  }

  /* ══════════════════════════════════════════════════
     PORTFOLIO SECTION
     ══════════════════════════════════════════════════ */

  .portfolio-section {
    background: var(--color-bg);
  }

  .portfolio-heading {
    font-size: var(--text-3xl);
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .portfolio-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .portfolio-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base);
    box-shadow: var(--shadow-sm);
  }

  .portfolio-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  /* Placeholder thumbnail */
  .portfolio-thumbnail {
    width: 100%;
    height: 180px;
    background: var(--color-bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .portfolio-thumbnail-label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-brand);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  /* Subtle diagonal accent on thumbnail */
  .portfolio-thumbnail::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      135deg,
      transparent 40%,
      rgba(var(--color-brand-rgb), 0.08) 100%
    );
    pointer-events: none;
  }

  .portfolio-body {
    padding: var(--space-6);
  }

  .portfolio-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .portfolio-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-regular);
    color: var(--color-brand-dark);
    background: var(--color-brand-subtle);
    border-radius: var(--radius-full);
    line-height: var(--leading-normal);
  }

  .portfolio-link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-brand-dark);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color var(--transition-fast);
  }

  .portfolio-link:hover {
    color: var(--color-brand);
  }

  /* Desktop: asymmetric side-by-side */
  @media (min-width: 769px) {
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: var(--space-8);
      align-items: start;
    }

    .portfolio-card--wide {
      grid-column: 1 / 8;
    }

    .portfolio-card--narrow {
      grid-column: 7 / 13;
      margin-top: var(--space-12);
    }

    .portfolio-thumbnail {
      height: 260px;
    }

    .portfolio-title {
      font-size: var(--text-2xl);
    }

    .portfolio-body {
      padding: var(--space-8);
    }
  }
</style>
