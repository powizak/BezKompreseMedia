---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceHero from '../components/ServiceHero.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import PageCTA from '../components/PageCTA.astro';
import { fotoHero, fotoCategories, fotoGalleries, fotoGalleryNote } from '../data/foto';

const categoryGridHeading = "Kategorie služeb";
const categoryGridIntro = "Veškeré naše jednotlivé služby jsou poskytovány na profesionální úrovni a nemusíte se bát jakoukoliv z nich využít. Pokud nenajdete kategorii, kterou hledáte, i tak se neváhejte ozvat.";
---

<BaseLayout title="Foto - BezKomprese Media">
  <ServiceHero
    title={fotoHero.title}
    subtitle={fotoHero.subtitle}
    intro={fotoHero.intro}
  />

  <CategoryGrid
    heading={categoryGridHeading}
    intro={categoryGridIntro}
    categories={fotoCategories}
  />

  <!-- Gallery note -->
  <section class="section">
    <div class="container">
      <p class="gallery-note scroll-reveal" set:html={fotoGalleryNote.replace('ZDE', '<a href="/galerie/">ZDE</a>')} />
    </div>
  </section>

  <!-- Gallery sections -->
  <section class="section gallery-sections">
    <div class="container">
      {fotoGalleries.map((gallery, i) => (
        <div class="gallery-section scroll-reveal" data-delay={i * 100}>
          <div class="gallery-section-header">
            <h2 class="gallery-section-title">{gallery.title}</h2>
            <p class="gallery-section-desc">{gallery.description}</p>
          </div>
          {gallery.photos.length > 0 ? (
            <div class="gallery-grid">
              {gallery.photos.map((photo) => (
                <a href={photo.src} class="glightbox gallery-photo" data-gallery={gallery.title}>
                  <img
                    src={photo.src}
                    alt={photo.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              ))}
            </div>
          ) : null}
        </div>
      ))}
    </div>
  </section>

  <PageCTA />
</BaseLayout>

<style>
  /* === Gallery Note === */
  .gallery-note {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    line-height: var(--leading-relaxed);
    color: var(--color-text-light);
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
  }

  .gallery-note :global(a) {
    color: var(--color-brand-dark);
    font-weight: var(--weight-bold);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .gallery-note :global(a):hover {
    color: var(--color-brand);
  }

  /* === Gallery Sections === */
  .gallery-sections {
    padding-top: 0;
  }

  .gallery-section {
    margin-bottom: var(--space-16);
  }

  .gallery-section:last-child {
    margin-bottom: 0;
  }

  .gallery-section-header {
    margin-bottom: var(--space-8);
  }

  .gallery-section-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-black);
    margin-bottom: var(--space-3);
  }

  .gallery-section-desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    line-height: var(--leading-relaxed);
    color: var(--color-text-light);
    max-width: 600px;
  }

  /* === Gallery Grid: mobile-first === */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .gallery-photo {
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg-alt);
    text-decoration: none;
    color: inherit;
  }

  .gallery-photo img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--transition-base);
  }

  .gallery-photo:hover img {
    transform: scale(1.02);
  }

  /* === Desktop: 2-col grid === */
  @media (min-width: 769px) {
    .gallery-section-title {
      font-size: var(--text-3xl);
    }

    .gallery-section-desc {
      max-width: 700px;
      font-size: var(--text-lg);
    }

    .gallery-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }
  }
</style>
