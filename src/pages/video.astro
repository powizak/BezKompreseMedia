---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceHero from '../components/ServiceHero.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import PageCTA from '../components/PageCTA.astro';
import {
  videoHero,
  videoCategories,
  videoGalleries,
  videoGalleryNote,
} from '../data/video';

// Parse gallery note to make "ZDE" a link to /galerie/
const noteParts = videoGalleryNote.split('ZDE');
---

<BaseLayout title="Video - BezKomprese Media">
  <ServiceHero
    title={videoHero.title}
    subtitle={videoHero.subtitle}
    intro={videoHero.intro}
  />

  <CategoryGrid
    heading="Kategorie služeb"
    intro="Veškeré naše jednotlivé služby jsou poskytovány na profesionální úrovni a nemusíte se bát jakoukoliv z nich využít. Pokud nenajdete kategorii, kterou hledáte, i tak se neváhejte ozvat."
    categories={videoCategories}
  />

  <!-- Gallery note -->
  <section class="section">
    <div class="container">
      <div class="gallery-note scroll-reveal">
        <p class="gallery-note__text">
          {noteParts[0]}<a href="/galerie/" class="gallery-note__link">ZDE</a>{noteParts[1]}
        </p>
      </div>
    </div>
  </section>

  <!-- 6 Gallery sections -->
  {videoGalleries.map((gallery, i) => (
    <section class="section gallery-section-wrapper">
      <div class="container">
        <div class="gallery-section scroll-reveal" data-delay={i * 100}>
          <div class="gallery-section-header">
            <h2 class="gallery-section__title">{gallery.title}</h2>
            <p class="gallery-section__desc">{gallery.description}</p>
          </div>
          <div class="gallery-grid">
            <div class="gallery-placeholder gallery-placeholder--wide">
              <span class="gallery-placeholder__label">Video ukázka</span>
            </div>
            <div class="gallery-placeholder gallery-placeholder--tall">
              <span class="gallery-placeholder__label">Video ukázka</span>
            </div>
            <div class="gallery-placeholder">
              <span class="gallery-placeholder__label">Video ukázka</span>
            </div>
            <div class="gallery-placeholder">
              <span class="gallery-placeholder__label">Video ukázka</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <PageCTA />
</BaseLayout>

<style>
  /* ── Gallery Note ────────────────────────────── */
  .gallery-note {
    text-align: center;
    padding: var(--space-8);
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .gallery-note__text {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .gallery-note__link {
    color: var(--color-brand-dark);
    font-weight: var(--weight-bold);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .gallery-note__link:hover {
    color: var(--color-brand);
  }

  /* ── Gallery Section Wrapper (alternating bg) ── */
  .gallery-section-wrapper:nth-of-type(odd) {
    background: var(--color-bg-alt);
  }

  .gallery-section-wrapper:nth-of-type(even) {
    background: var(--color-bg);
  }

  /* ── Gallery Section Header ──────────────────── */
  .gallery-section {
    width: 100%;
  }

  .gallery-section-header {
    margin-bottom: var(--space-10);
  }

  .gallery-section__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-black);
    margin-bottom: var(--space-3);
    position: relative;
  }

  .gallery-section__title::after {
    content: '';
    display: block;
    width: 48px;
    height: 3px;
    background: var(--color-brand);
    margin-top: var(--space-3);
    border-radius: var(--radius-sm);
  }

  .gallery-section__desc {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-light);
    max-width: 640px;
  }

  /* ── Gallery Grid: mobile-first ──────────────── */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  /* ── Gallery Placeholder ─────────────────────── */
  .gallery-placeholder {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .gallery-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      var(--color-bg-alt) 0%,
      var(--color-bg) 100%
    );
    opacity: 0.6;
  }

  .gallery-placeholder--wide {
    min-height: 220px;
  }

  .gallery-placeholder--tall {
    min-height: 280px;
  }

  .gallery-placeholder__label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text-light);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    position: relative;
    z-index: var(--z-base);
  }

  /* ── Desktop: asymmetric 12-col grid ─────────── */
  @media (min-width: 769px) {
    .gallery-section__title {
      font-size: var(--text-3xl);
    }

    .gallery-section__desc {
      font-size: var(--text-lg);
    }

    .gallery-grid {
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto auto;
      gap: var(--space-5);
    }

    .gallery-placeholder--wide {
      grid-column: 1 / 8;
      min-height: 300px;
    }

    .gallery-placeholder--tall {
      grid-column: 8 / 13;
      grid-row: 1 / 3;
      min-height: 100%;
    }

    .gallery-placeholder:nth-of-type(3) {
      grid-column: 1 / 6;
      min-height: 240px;
    }

    .gallery-placeholder:nth-of-type(4) {
      grid-column: 6 / 8;
      min-height: 240px;
    }
  }
</style>
