---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceHero from '../components/ServiceHero.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import PageCTA from '../components/PageCTA.astro';
import {
  videoHero,
  videoCategories,
  videoGalleries,
  videoGalleryNote,
} from '../data/video';

// Parse gallery note to make "ZDE" a link to /galerie/
const noteParts = videoGalleryNote.split('ZDE');
---

<BaseLayout title="Video - BezKomprese Media">
  <ServiceHero
    title={videoHero.title}
    subtitle={videoHero.subtitle}
    intro={videoHero.intro}
  />

  <CategoryGrid
    heading="Kategorie služeb"
    intro="Veškeré naše jednotlivé služby jsou poskytovány na profesionální úrovni a nemusíte se bát jakoukoliv z nich využít. Pokud nenajdete kategorii, kterou hledáte, i tak se neváhejte ozvat."
    categories={videoCategories}
  />

  <!-- Gallery note -->
  <section class="section">
    <div class="container">
      <div class="gallery-note scroll-reveal">
        <p class="gallery-note__text">
          {noteParts[0]}<a href="/galerie/" class="gallery-note__link">ZDE</a>{noteParts[1]}
        </p>
      </div>
    </div>
  </section>

  <!-- Gallery sections -->
  {videoGalleries.map((gallery, gi) => (
    <section class="section gallery-section-wrapper">
      <div class="container">
        <div class="gallery-section scroll-reveal" data-delay={gi * 100}>
          <div class="gallery-section-header">
            <h2 class="gallery-section__title">{gallery.title}</h2>
            <p class="gallery-section__desc">{gallery.description}</p>
          </div>
          <div class="gallery-grid">
            {gallery.videos.map((video, vi) => (
              <div class="gallery-video">
                <div class="video-responsive">
                  <iframe
                    src={`https://www.youtube.com/embed/${video.youtubeId}`}
                    title={`${gallery.title} – ukázka ${vi + 1}`}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    loading="lazy"
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  ))}

  <PageCTA />
</BaseLayout>

<style>
  /* ── Gallery Note ────────────────────────────── */
  .gallery-note {
    text-align: center;
    padding: var(--space-8);
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .gallery-note__text {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .gallery-note__link {
    color: var(--color-brand-dark);
    font-weight: var(--weight-bold);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .gallery-note__link:hover {
    color: var(--color-brand);
  }

  /* ── Gallery Section Wrapper (alternating bg) ── */
  .gallery-section-wrapper:nth-of-type(odd) {
    background: var(--color-bg-alt);
  }

  .gallery-section-wrapper:nth-of-type(even) {
    background: var(--color-bg);
  }

  /* ── Gallery Section Header ──────────────────── */
  .gallery-section {
    width: 100%;
  }

  .gallery-section-header {
    margin-bottom: var(--space-10);
  }

  .gallery-section__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-black);
    margin-bottom: var(--space-3);
    position: relative;
  }

  .gallery-section__title::after {
    content: '';
    display: block;
    width: 48px;
    height: 3px;
    background: var(--color-brand);
    margin-top: var(--space-3);
    border-radius: var(--radius-sm);
  }

  .gallery-section__desc {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-light);
    max-width: 640px;
  }

  /* ── Gallery Grid: mobile-first ──────────────── */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  /* ── Video Responsive Container ─────────────── */
  .gallery-video {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-black);
  }

  .video-responsive {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
  }

  .video-responsive iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── Desktop: uniform 2-col grid ─────────────── */
  @media (min-width: 769px) {
    .gallery-section__title {
      font-size: var(--text-3xl);
    }

    .gallery-section__desc {
      font-size: var(--text-lg);
    }

    .gallery-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }
  }
</style>
