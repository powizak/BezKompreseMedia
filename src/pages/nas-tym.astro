---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceHero from '../components/ServiceHero.astro';
import TeamCard from '../components/TeamCard.astro';
import PageCTA from '../components/PageCTA.astro';
import { teamHero, teamIntro, teamMembers } from '../data/team';
---

<BaseLayout title="Náš tým - BezKomprese Media">
  <ServiceHero
    title={teamHero.title}
    subtitle={teamHero.subtitle}
    intro={teamHero.intro}
  />

  <section class="section team-section">
    <div class="container">
      <div class="team-intro scroll-reveal">
        <h2 class="team-intro__heading">Kdo jsme</h2>
        <p class="team-intro__text">{teamIntro}</p>
      </div>

      <div class="team-grid">
        <div class="team-grid__item team-grid__item--featured scroll-reveal" data-delay="0">
          <TeamCard
            name={teamMembers[0].name}
            role={teamMembers[0].role}
            bio={teamMembers[0].bio}
            socials={teamMembers[0].socials}
          />
        </div>
        {teamMembers.slice(1).map((member, i) => (
          <div class={`team-grid__item team-grid__item--member scroll-reveal`} data-delay={String((i + 1) * 100)}>
            <TeamCard
              name={member.name}
              role={member.role}
              bio={member.bio}
              socials={member.socials}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <PageCTA />
</BaseLayout>

<style>
  /* ── Intro block ─────────────────────────────── */
  .team-intro {
    max-width: 680px;
    margin-bottom: var(--space-12);
  }

  .team-intro__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-black);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .team-intro__heading::after {
    content: '';
    display: block;
    width: 48px;
    height: 3px;
    background: var(--color-brand);
    margin-top: var(--space-3);
    border-radius: var(--radius-sm);
  }

  .team-intro__text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
  }

  /* ── Team grid ───────────────────────────────── */
  .team-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .team-grid__item {
    width: 100%;
  }

  /* ── Desktop asymmetric layout ───────────────── */
  @media (min-width: 769px) {
    .team-intro__heading {
      font-size: var(--text-3xl);
    }

    .team-intro__text {
      font-size: var(--text-lg);
    }

    .team-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }

    .team-grid__item--featured {
      grid-column: 1 / -1;
      transform: translateY(-8px);
      max-width: 75%;
    }

    .team-grid__item--member:nth-child(2) {
      transform: translateY(16px);
    }

    .team-grid__item--member:nth-child(3) {
      transform: translateY(-12px);
    }

    .team-grid__item--member:nth-child(4) {
      transform: translateY(8px);
    }
  }

  @media (min-width: 1024px) {
    .team-grid__item--featured {
      max-width: 65%;
    }

    .team-grid__item--member:nth-child(2) {
      transform: translateY(24px);
    }

    .team-grid__item--member:nth-child(3) {
      transform: translateY(-16px);
    }

    .team-grid__item--member:nth-child(4) {
      transform: translateY(12px);
    }
  }
</style>
