# hCaptcha (PUBLIC_ prefix = exposed to the client at build time)
PUBLIC_HCAPTCHA_SITE_KEY=your_site_key_here

# hCaptcha secret key — server-side only. Locally unused (PHP runs only on
# the WEDOS server); in CI it is provided as a GitHub Actions secret and
# written to dist/config.php at deploy time.
HCAPTCHA_SECRET_KEY=your_secret_key_here

# CookieYes (PUBLIC_ prefix required for client-side access)
PUBLIC_COOKIEYES_ID=your_cookieyes_id_here
